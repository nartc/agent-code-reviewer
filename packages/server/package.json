{
    "name": "@agent-code-reviewer/server",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "test": "vitest run"
    },
    "dependencies": {
        "@agent-code-reviewer/shared": "workspace:*",
        "@hono/node-server": "^1.19.10",
        "@hono/zod-validator": "^0.7.6",
        "hono": "^4.12.5",
        "nanoid": "^5.1.6",
        "neverthrow": "^8.2.0",
        "simple-git": "^3.32.3",
        "sql.js": "^1.14.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "vitest": "^4.0.18"
    },
    "nx": {
        "name": "server",
        "projectType": "application",
        "sourceRoot": "packages/server/src",
        "targets": {
            "serve": {
                "command": "tsx watch --env-file=packages/server/.env packages/server/src/index.ts",
                "options": {
                    "cwd": "{workspaceRoot}"
                }
            }
        }
    }
}
